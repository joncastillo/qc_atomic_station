{
  "name": "qc-atomic-station",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npx tsx src/build.ts",
    "build:minify": "npx tsx src/build.ts --minify",
    "dev": "npm run build && concurrently -n frontend,backend \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npx @tailwindcss/cli -i src/frontend/style2.css -o dist/public/style2.css --watch",
    "dev:backend": "node dist/backend/index.js",
    "start": "npx tsx src/build.ts --minify && NODE_ENV=production node dist/backend/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "ip-matching": "^2.1.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
